# Copie este arquivo para .env e preencha os valores antes de rodar o Docker.
# O arquivo .env NUNCA deve ser commitado no git.

# Banco de dados PostgreSQL
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# Chave secreta para assinatura dos tokens JWT
# IMPORTANTE: Use uma chave longa e aleatória em produção!
JWT_SECRET=mude_esta_chave_em_producao
